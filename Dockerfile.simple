# Simple development container without dependencies
FROM node:18-alpine

WORKDIR /app

# Install system dependencies
RUN apk add --no-cache git curl

# Create non-root user
RUN addgroup -g 1001 -S nodejs
RUN adduser -S developer -u 1001

# Copy source code
COPY . .

# Change ownership
RUN chown -R developer:nodejs /app

USER developer

EXPOSE 3000 4000 4001

# Simple bash shell to allow manual dependency management
CMD ["sh"]
