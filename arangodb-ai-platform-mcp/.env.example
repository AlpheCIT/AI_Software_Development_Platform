# MCP Server Environment Configuration
# Copy this to .env and modify as needed

# ArangoDB Connection Settings
ARANGO_URL=http://192.168.1.82:8529
ARANGO_DB=ARANGO_AISDP_DB
ARANGO_USERNAME=root
ARANGO_PASSWORD=openSesame

# Server Configuration
NODE_ENV=production
PORT=8080
HOST=0.0.0.0

# Security Settings
ENABLE_WRITES=true
ENABLE_DATABASE_MANAGEMENT=true
ENABLE_COLLECTION_MANAGEMENT=true
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Origin,X-Requested-With,Content-Type,Accept,Authorization

# SSL/HTTPS Configuration (for production)
HTTPS_ENABLED=false
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem
SSL_CA_PATH=./ssl/ca.pem

# Performance Settings
DEFAULT_LIMIT=500
GRAPH_BATCH_SIZE=2000
MAX_SEARCH_RESULTS=100
MAX_EXPANSION_DEPTH=3
MAX_DOCUMENT_PREVIEW=50
REQUEST_TIMEOUT=30000

# Advanced Features
ENABLE_SEMANTIC_SEARCH=true
ENABLE_BULK_OPERATIONS=true
ENABLE_DATA_EXPORT=true
ENABLE_CACHE=true
CACHE_TTL=300000
CACHE_MAX_SIZE=1000

# Logging Configuration
LOG_LEVEL=info
LOG_PRETTY=false
LOG_FILE=./logs/mcp-server.log
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# Development Settings (disable in production)
DEBUG_MODE=false
VERBOSE_LOGGING=false
ENABLE_SWAGGER_DOCS=false
