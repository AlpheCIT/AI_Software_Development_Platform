# Production Environment Configuration
NODE_ENV=production

# Demo Data Control (CRITICAL: set to false for investor demo)
ENABLE_DEMO_DATA=false

# Service URLs
PORT=3001
REPOSITORY_SERVICE_URL=http://localhost:8080
VECTOR_SEARCH_URL=http://localhost:8081
MCP_SERVER_URL=http://localhost:3002

# ArangoDB Configuration (Production)
ARANGO_HOST=localhost
ARANGO_PORT=8529
ARANGO_URL=http://localhost:8529
ARANGO_DATABASE=ARANGO_AISDP_DB
ARANGO_DATABASE=ARANGO_AISDP_DB
ARANGO_USERNAME=root
ARANGO_USER=root
ARANGO_PASSWORD=openSesame
ARANGODB_USERNAME=root
ARANGODB_PASSWORD=openSesame
ARANGODB_NAME=ARANGO_AISDP_DB

# Redis Configuration (Production)
REDIS_URL=redis://localhost:6379

# Ollama Configuration (Production)
OLLAMA_URL=http://localhost:11434

# API Configuration
API_PORT=3001
API_HOST=0.0.0.0

# Dashboard Configuration
DASHBOARD_PORT=3000
DASHBOARD_HOST=0.0.0.0

# Security
JWT_SECRET=your-secure-jwt-secret-here
CORS_ORIGIN=https://your-domain.com
