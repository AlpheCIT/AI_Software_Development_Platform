{
  "name": "ai-software-development-platform",
  "version": "3.0.0",
  "description": "Event-Driven Repository Analysis Platform with comprehensive analyzers",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "packageManager": "npm@10.2.0",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node platform-launcher.js",
    "stop": "node platform-stopper.js",
    "start:frontend": "cd apps/frontend && npm run dev",
    "start:api-gateway": "cd apps/api-gateway && npm run dev",
    "start:websocket": "cd services/websocket && npm run dev",
    "start:ingestion": "cd services/ingestion-engine && npm run dev",
    "start:analysis": "cd services/analysis-engine && npm run dev",
    "start:policy": "cd services/policy-engine && npm run dev",
    "start:policy-gateway": "cd apps/policy-gateway && npm run dev",
    "start:mcp-proxy": "node mcp-proxy-server.js",
    "start:project-mgmt": "concurrently \"npm run start:mcp-proxy\" \"npm run start:frontend\"",
    "demo:project-mgmt": "node mcp-project-management-demo.js",
    "setup": "powershell -ExecutionPolicy Bypass -File install-dependencies.ps1",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "build:prod": "turbo run build --env=production",
    "test": "turbo run test",
    "test:e2e": "cd tests/e2e && npm run test",
    "test:integration": "cd tests/integration && npm run test",
    "test:unit": "cd tests/unit && npm run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules/.cache",
    "validate:structure": "node scripts/setup/validate-structure.js",
    "platform:start": "node scripts/platform-launcher.js",
    "platform:stop": "node scripts/platform-stopper.js",
    "platform:status": "node scripts/platform-status.js",
    "health": "node scripts/health-check.js",
    "db:create-collections": "node scripts/database/create-collections.js",
    "db:create-indexes": "node scripts/database/create-indexes.js",
    "db:seed-demo": "node scripts/database/seed-demo-data.js",
    "db:setup": "npm run db:create-collections && npm run db:create-indexes && npm run db:seed-demo",
    "docker:up": "docker-compose -f ops/docker-compose/docker-compose.yml up -d",
    "docker:down": "docker-compose -f ops/docker-compose/docker-compose.yml down",
    "docker:logs": "docker-compose -f ops/docker-compose/docker-compose.yml logs -f",
    "docker:dev": "docker-compose -f ops/docker-compose/docker-compose.dev.yml up -d",
    "contracts:generate": "npm run contracts:openapi && npm run contracts:asyncapi",
    "contracts:openapi": "openapi-generator-cli generate -i contracts/openapi/api-gateway.yaml -g typescript-node -o packages/shared-types/src/api",
    "contracts:asyncapi": "asyncapi generate fromTemplate contracts/asyncapi/events.yaml @asyncapi/typescript-template -o packages/shared-types/src/events"
  },
  "dependencies": {
    "@antv/g6": "^5.0.49",
    "@antv/graphin": "^3.0.5",
    "@chakra-ui/icons": "^2.2.4",
    "arangojs": "^8.8.1",
    "axios": "^1.11.0",
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "compression": "^1.8.1",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.1.0",
    "inquirer": "^9.2.0",
    "listr2": "^7.0.0",
    "morgan": "^1.10.1",
    "ora": "^7.0.0",
    "react-beautiful-dnd": "^13.1.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "wait-on": "^7.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "@openapitools/openapi-generator-cli": "^2.7.0",
    "@asyncapi/generator": "^1.17.0",
    "eslint": "^8.48.0",
    "prettier": "^3.0.0",
    "turbo": "^1.10.0",
    "typescript": "^5.2.0"
  },
  "keywords": [
    "ai",
    "code-intelligence",
    "software-development",
    "platform",
    "event-driven",
    "microservices",
    "analysis"
  ],
  "author": "AI Software Development Platform Team",
  "license": "MIT"
}