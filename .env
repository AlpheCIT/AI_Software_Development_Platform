# AI Software Development Platform - Frontend Environment Configuration
# Environment variables for Vite frontend (must be prefixed with VITE_)

# Environment
VITE_NODE_ENV=development

# API Configuration
VITE_API_BASE_URL=http://localhost:3001
VITE_API_TIMEOUT=10000
VITE_MAX_RETRIES=3
VITE_RETRY_DELAY=1000

# WebSocket Configuration
VITE_WEBSOCKET_URL=http://localhost:4001
VITE_WEBSOCKET_ENABLED=true
VITE_WEBSOCKET_CORS_ORIGIN=http://localhost:3000

# Polling Configuration
VITE_ENABLE_POLLING=true
VITE_POLLING_INTERVAL=5000

# Backend API Gateway Configuration (for reference)
# These are used by the backend services
PORT=3001
NODE_ENV=development

# CORS Configuration  
CORS_ORIGIN=http://localhost:3000

# ArangoDB Configuration
ARANGO_URL=http://localhost:8529
ARANGO_DATABASE=ARANGO_AISDP_DB
ARANGO_USER=root
ARANGO_PASSWORD=

# WebSocket Configuration (Backend)
WEBSOCKET_ENABLED=true
WEBSOCKET_CORS_ORIGIN=http://localhost:3000

# Ingestion Configuration
MAX_CONCURRENT_INGESTIONS=3
INGESTION_TIMEOUT=300000
TEMP_DIRECTORY=./temp

# Logging
LOG_LEVEL=info
LOG_REQUESTS=true

# Demo Configuration
DEMO_MODE=true
DEMO_REPOSITORIES=https://github.com/facebook/create-react-app,https://github.com/expressjs/express,https://github.com/vuejs/vue,https://github.com/microsoft/TypeScript