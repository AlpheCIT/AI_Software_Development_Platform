# AI Software Development Platform - Environment Configuration

# =============================================================================
# ARANGO DATABASE CONFIGURATION
# =============================================================================

# ArangoDB Configuration
ARANGO_URL=http://localhost:8529
ARANGO_HOST=localhost
ARANGO_PORT=8529
ARANGO_DATABASE=ARANGO_AISDP_DB
ARANGO_USERNAME=root
ARANGO_PASSWORD=openSesame
ARANGO_USE_CUSTOM_INDEX=true

# =============================================================================
# ARANGODB MCP COMPATIBILITY
# =============================================================================

# Security Settings (keep false for read-only mode)
ENABLE_WRITES=false

# Performance Settings
DEFAULT_LIMIT=500
GRAPH_BATCH_SIZE=2000
MAX_SEARCH_RESULTS=100
MAX_EXPANSION_DEPTH=3

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Cache Settings (optional)
ENABLE_CACHE=true
CACHE_TTL=300000

# Repository Settings
DEFAULT_REPOSITORY=main-repo
ANALYSIS_VERSION=1.0

# =============================================================================
# AI SERVICE CONFIGURATION
# =============================================================================

# AWS Bedrock Configuration (Primary AI Service)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
AWS_ANTHROPIC_VERSION=bedrock-2023-05-31
AWS_MAX_TOKENS=4000
AWS_TEMPERATURE=0.7
AWS_TOP_P=0.95
AWS_TIMEOUT=30000

# Claude 4.x Cross-Region Inference Profile (if available)
# AWS_BEARER_TOKEN_BEDROCK=your_bearer_token_here
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# OpenAI Configuration (Alternative AI Service)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_CHAT_MODEL=gpt-4
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Azure OpenAI Configuration
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_KEY=your_azure_openai_key_here
# AZURE_CHAT_DEPLOYMENT=gpt-4
# AZURE_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# Ollama Configuration (Local AI Service)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
EMBEDDING_BATCH_SIZE=20
EMBEDDING_CACHE_ENABLED=true

