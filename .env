# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# General Application Settings
NODE_ENV=development
LOG_LEVEL=info
USE_LOCAL_FALLBACK=true

# API Configuration
API_PORT=4000
API_HOST=localhost
GRAPHQL_PLAYGROUND=true
GRAPHQL_INTROSPECTION=true

# Service Ports (Production)
FRONTEND_PORT=3000
WEBSOCKET_PORT=4001
VECTOR_SEARCH_PORT=8005
REDIS_PORT=6379

# Development Ports (to avoid conflicts when running both)
ARANGO_PORT_DEV=8529
REDIS_PORT_DEV=6380
OLLAMA_PORT_DEV=11435

# Agent Configuration
AGENT_COORDINATION_ENABLED=true
A2A_COMMUNICATION_ENABLED=true
REAL_TIME_ANALYSIS=true

# WebSocket Configuration
WEBSOCKET_PORT=4001
WEBSOCKET_PATH=/ws

# =============================================================================
# ANALYSIS CONFIGURATION
# =============================================================================

# Repository Analysis Settings
REPO_TEMP_DIR=./temp
TENANT_ID=default
EXCLUDED_DIRS=node_modules,.git,__pycache__,venv,env,.env,.vscode,dist,build,.next,.nuxt,target
ANALYSIS_BATCH_SIZE=50
MAX_WORKERS=4

# Code Analysis Features
RUN_SECURITY_SCAN=true
RUN_CODE_QUALITY=true
RUN_PERFORMANCE_ANALYSIS=true
RUN_DEPENDENCY_ANALYSIS=true
RUN_AI_ENHANCEMENT=true

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Logging Configuration
LOG_FILE=ai_code_management.log
LOG_FORMAT=json
LOG_MAX_SIZE=100MB
LOG_MAX_FILES=10

# Metrics Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_PREFIX=ai_code_management

# Tracing Configuration
TRACING_ENABLED=true
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=30000
HEALTH_CHECK_INTERVAL=60000

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Authentication & Authorization
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
JWT_EXPIRES_IN=24h
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================

# Development Settings
HOT_RELOAD_ENABLED=true
DEBUG_MODE=false
ENABLE_DEV_TOOLS=true

# Testing Configuration
TEST_DATABASE_URL=http://localhost:8529
TEST_DATABASE_NAME=ARANGO_AISDP_DB
INTEGRATION_TESTS_ENABLED=true

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# Container Configuration
DOCKER_REGISTRY=your-registry.com
DOCKER_NAMESPACE=ai-code-management
CONTAINER_PORT=4000

# Kubernetes Configuration
KUBERNETES_NAMESPACE=ai-code-management
KUBERNETES_CLUSTER=production

# Resource Limits
MEMORY_LIMIT=2Gi
CPU_LIMIT=1000m
MEMORY_REQUEST=1Gi
CPU_REQUEST=500m

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Feature Toggles
FEATURE_AI_AGENTS=true
FEATURE_REAL_TIME_ANALYSIS=true
FEATURE_PREDICTIVE_ANALYTICS=true
FEATURE_AUTOMATED_REFACTORING=false
FEATURE_COMPLIANCE_CHECKER=true
FEATURE_PERFORMANCE_PROFILER=true

# Experimental Features
EXPERIMENTAL_GRAPH_ML=false
EXPERIMENTAL_CODE_GENERATION=false
EXPERIMENTAL_AUTOMATED_TESTING=false

