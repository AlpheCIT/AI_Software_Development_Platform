# Vector Search Service Configuration

# Service Configuration
VECTOR_SEARCH_PORT=8005
SERVICE_NAME=vector-search
NODE_ENV=development

# Database Configuration
ARANGO_URL=http://192.168.1.82:8529
ARANGO_DATABASE=ARANGO_AISDP_DB
ARANGO_USER=root
ARANGO_PASSWORD=your-arango-password-here

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Embedding Service Configuration
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=100

# Vector Search Configuration
DEFAULT_SIMILARITY_THRESHOLD=0.7
MAX_RESULTS_LIMIT=1000
CACHE_TTL_SECONDS=3600
ENABLE_HYBRID_SEARCH=true

# Performance Configuration
INDEX_OPTIMIZATION_ENABLED=true
PARALLEL_PROCESSING_ENABLED=true
MEMORY_LIMIT_MB=2048
QUERY_TIMEOUT_MS=30000

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=vector-search.log
