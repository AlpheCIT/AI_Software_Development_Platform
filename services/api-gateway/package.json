    "@fastify/swagger": "^8.12.0",
    "@fastify/swagger-ui": "^2.1.0",
    "mercurius": "^13.0.1",
    "graphql": "^16.8.1",
    "@graphql-tools/schema": "^10.0.0",
    "@graphql-tools/merge": "^9.0.0",
    "arangojs": "^8.8.1",
    "ioredis": "^5.3.2",
    "zod": "^3.22.4",
    "pino": "^8.16.2",
    "pino-pretty": "^10.2.3",
    "dotenv": "^16.3.1",
