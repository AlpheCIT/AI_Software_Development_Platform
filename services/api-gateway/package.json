{
  "name": "@ai-code-management/api-gateway",
  "version": "2.0.0",
  "private": true,
  "description": "GraphQL API Gateway with REST endpoints for AI Code Management System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
