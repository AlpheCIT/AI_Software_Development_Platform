# AI Software Development Platform - Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# ArangoDB Connection
ARANGO_HOST=localhost
ARANGO_PORT=8529
ARANGO_URL=http://localhost:8529
ARANGO_DATABASE=ARANGO_AISDP_DB
ARANGO_DATABASE=ARANGO_AISDP_DB
ARANGO_USERNAME=root
ARANGO_USER=root
ARANGO_PASSWORD=openSesame
ARANGODB_USERNAME=root
ARANGODB_PASSWORD=openSesame
ARANGODB_NAME=ARANGO_AISDP_DB

# Database Pool Settings
ARANGODB_POOL_SIZE=10
ARANGODB_TIMEOUT=30000
ARANGODB_MAX_RETRIES=3

# =============================================================================
# API GATEWAY CONFIGURATION
# =============================================================================

# Server Settings
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS Configuration
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# WEBSOCKET CONFIGURATION
# =============================================================================

# WebSocket Server
WEBSOCKET_PORT=3001
WEBSOCKET_PATH=/socket.io

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Password Hashing
BCRYPT_ROUNDS=12

# API Keys (if needed)
API_KEY_HEADER=x-api-key
ADMIN_API_KEY=your-admin-api-key

# =============================================================================
# AI SERVICES CONFIGURATION
# =============================================================================

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# AWS Bedrock Configuration (alternative)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
BEDROCK_MODEL_ID=anthropic.claude-v2

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log Levels: error, warn, info, debug
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=100m
LOG_MAX_FILES=5

# =============================================================================
# PERFORMANCE & MONITORING
# =============================================================================

# Analysis Settings
DEFAULT_BATCH_SIZE=10
MAX_FILE_SIZE=10485760
ANALYSIS_TIMEOUT=300000

# Health Check
HEALTH_CHECK_INTERVAL=30000
METRICS_REFRESH_INTERVAL=60000

# =============================================================================
# FILE PROCESSING
# =============================================================================

# File Upload
MAX_UPLOAD_SIZE=100mb
UPLOAD_PATH=./uploads
TEMP_PATH=./temp

# Supported File Extensions
SUPPORTED_EXTENSIONS=.js,.jsx,.ts,.tsx,.py,.java,.cs,.cpp,.go,.rs,.php,.rb

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Development Mode
DEBUG=ai-code-management:*
VERBOSE_LOGGING=true

# Hot Reload
WATCH_FILES=true
RELOAD_ON_CHANGE=true

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================

# Production Optimizations
ENABLE_COMPRESSION=true
ENABLE_CACHING=true
CACHE_TTL=3600

# Security Headers
ENABLE_HELMET=true
ENABLE_RATE_LIMITING=true

# =============================================================================
# DOCKER & DEPLOYMENT
# =============================================================================

# Docker Configuration
DOCKER_REGISTRY=your-docker-registry
DOCKER_IMAGE_TAG=latest

# Deployment
DEPLOY_ENVIRONMENT=development
DEPLOY_REGION=us-east-1

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# Jira Integration
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token-here
JIRA_BASE_URL=https://alphavirtusai.atlassian.net
JIRA_CLOUD_ID=1961cbad-828b-4775-b0ec-7769f91b35dc

# Email Service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Slack Integration (for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#ai-code-management

# GitHub Integration
GITHUB_TOKEN=your-github-token
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/Disable Features
ENABLE_AI_INSIGHTS=true
ENABLE_SECURITY_SCANNING=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_REAL_TIME_UPDATES=true
ENABLE_DEPENDENCY_TRACKING=true
ENABLE_CODE_SUGGESTIONS=true

# Experimental Features
ENABLE_EXPERIMENTAL_FEATURES=false
ENABLE_BETA_AI_MODELS=false

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30

# =============================================================================
# ANALYTICS & TELEMETRY
# =============================================================================

# Analytics
ENABLE_ANALYTICS=true
ANALYTICS_RETENTION_DAYS=90

# Telemetry
ENABLE_TELEMETRY=false
TELEMETRY_ENDPOINT=https://telemetry.your-service.com

# =============================================================================
# CUSTOM CONFIGURATION
# =============================================================================

# Organization Settings
ORGANIZATION_NAME=Your Organization
ORGANIZATION_DOMAIN=your-domain.com

# Branding
BRAND_COLOR=#00d4aa
BRAND_LOGO_URL=https://your-domain.com/logo.png

# Custom Endpoints
CUSTOM_API_ENDPOINT=https://api.your-service.com
CUSTOM_WEBHOOK_URL=https://webhook.your-service.com
